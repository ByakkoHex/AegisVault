{
  "manifest_version": 3,
  "name": "AegisVault",
  "version": "1.2.5",
  "description": "Automatyczne uzupełnianie haseł z AegisVault — bezpieczny menedżer haseł.",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "AegisVault"
  },

  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["lib/browser-polyfill.js", "content/content_script.js"],
      "css": ["content/content_style.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "permissions": [
    "nativeMessaging",
    "activeTab",
    "storage",
    "scripting",
    "alarms"
  ],

  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],

  "commands": {
    "autofill": {
      "suggested_key": {
        "default": "Alt+Shift+F",
        "mac": "Alt+Shift+F"
      },
      "description": "Uzupełnij formularz przez AegisVault"
    }
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "aegisvault@aegisvault.pl",
      "strict_min_version": "109.0"
    }
  }
}
