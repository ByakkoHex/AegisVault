# .env.example — Skopiuj do .env i wypełnij przed uruchomieniem
# Nigdy nie commituj pliku .env do repozytorium!

# ── WYMAGANE ─────────────────────────────────────────────────────────
# Klucz JWT (minimum 32 znaki)
# Generuj: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32

# ── OPCJONALNE ───────────────────────────────────────────────────────
# Ścieżka bazy danych wewnątrz kontenera (zmontowanego wolumenu)
DB_PATH=/data/server_data.db

# Liczba workerów uvicorn
UVICORN_WORKERS=2

# ── TYLKO PRODUKCJA (docker-compose.prod.yml) ────────────────────────
# Twoja domena (bez https://)
DOMAIN=sync.twojadomena.pl

# Email dla Let's Encrypt (powiadomienia o wygasaniu certyfikatu)
CERTBOT_EMAIL=admin@twojadomena.pl
